# Copy to .env for local dev. On Railway, set these in the service Variables tab.

# Required — Railway's PostgreSQL plugin injects this automatically.
DATABASE_URL=postgresql://user:password@localhost:5432/visionsearch

# Required — generate one and keep it constant, or every restart loses your data.
# Generate:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Required — pick any long random string. Reused across restarts to keep users logged in.
# Generate:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Optional — recommended for Railway because BLIP / SentenceTransformers are huge.
# Free key from https://cohere.com
COHERE_API_KEY=

# Optional — connection-pool ceiling. Railway free tier: leave at default.
DB_POOL_MAX=10

# Optional — where to write thumbnails. Point at a Railway Volume mount for persistence.
UPLOAD_DIR=
